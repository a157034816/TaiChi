{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceCircuitToml": {
    "FilePath": "data/service-circuit.toml",
    "CleanupIntervalMinutes": 60
  },
  "ServiceCircuitJson": {
    "FilePath": "data/service-circuit.services.json"
  },
  "ManagedWebApps": {
    "PollIntervalSeconds": 5,
    "Definitions": [
      {
        "Name": "central-service-admin-site",
        "Enabled": true,
        "WorkingDirectory": "../central-service-admin-site",
        "Command": "npm",
        "Arguments": [
          "run",
          "start",
          "--",
          "--hostname",
          "0.0.0.0",
          "--port",
          "3000"
        ],
        "EnvironmentVariables": {
          "CENTRAL_SERVICE_BASE_URL": "http://127.0.0.1:15700"
        },
        "RequiredPaths": [
          ".next/BUILD_ID"
        ],
        "PrepareCommand": "npm",
        "PrepareArguments": [
          "run",
          "build"
        ],
        "PrepareTimeoutSeconds": 600,
        "HealthCheckUrl": "http://127.0.0.1:3000/",
        "StartupTimeoutSeconds": 60,
        "HealthCheckTimeoutSeconds": 5,
        "MaxConsecutiveHealthFailures": 3,
        "RestartDelaySeconds": 5
      }
    ]
  }
}
