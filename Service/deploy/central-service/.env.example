CENTRAL_DOMAIN=centralservice.y-bf.lol
API_DOMAIN=api.y-bf.lol

# Let's Encrypt 联系邮箱（用于到期/风控通知）。部署前请改为真实邮箱。
LETSENCRYPT_EMAIL=your@email.com

# 首个管理员账号（仅在数据库中没有任何用户时写入）。
CENTRAL_ADMIN_USERNAME=admin
CENTRAL_ADMIN_PASSWORD=please-change-me

# 反向代理密钥：Caddy 与后端共享，用于防止直连伪造 X-Forwarded-* 头。
PROXY_SECRET=please-change-me-to-a-strong-random-value

# 可选：离线发布包默认使用这两个镜像标签；若你自行改过导出标签，可在这里覆盖。
# CENTRALSERVICE_IMAGE=taichi/centralservice:latest
# ADMIN_SITE_IMAGE=taichi/centralservice-admin-site:latest
